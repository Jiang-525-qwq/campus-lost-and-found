.search-section {
  background: #fff;
  padding: 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #eee;
}

.search-bar {
  display: flex;
  margin-bottom: 20rpx;
}

.search-bar input {
  flex: 1;
  border: 2rpx solid #07c160;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #07c160;
  color: white;
  border-radius: 50rpx;
  padding: 0 40rpx;
  margin-left: 20rpx;
  font-size: 28rpx;
  height:auto;
  line-height:100rpx;
}

.filter-tabs {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0;
}

.tab {
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.tab.active {
  background: #07c160;
  color: white;
}

.sort-options {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
}

.sort-options picker {
  flex: 1;
  text-align: center;
  padding: 10rpx;
}

.post-list {
  height: calc(100vh - 300rpx);
  padding: 20rpx;
}

.post-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.post-type {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: white;
}

.post-type.lost {
  background: #ff6b6b;
}

.post-type.found {
  background: #4cd964;
}

.post-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.post-image image {
  width: 100%;
  height: 100%;
}

.post-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #333;
}

.post-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.post-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
}

.post-status {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.post-status.pending {
  background: #fff3cd;
  color: #856404;
}

.post-status.claimed {
  background: #d1ecf1;
  color: #0c5460;
}

.loading,
.no-more,
.empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}

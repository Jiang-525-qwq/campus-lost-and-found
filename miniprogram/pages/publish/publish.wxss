/* miniprogram/pages/publish/publish.wxss */

/* 页面整体样式 */
.publish-page {
  min-height: 100vh;
  background-color: #f8f9fa;
  padding: 20rpx 30rpx 100rpx;
  box-sizing: border-box;
}

/* 表单项通用样式 */
.form-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-item .label {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

/* 发布类型选择器 */
.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.type-option.active {
  background-color: #e8f5e9;
  color: #07c160;
  border-color: #07c160;
  font-weight: 500;
}

/* 输入框和文本域 */
.form-item input,
.form-item textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
  background: transparent;
  border: none;
  outline: none;
  padding: 0;
}

.form-item textarea {
  min-height: 150rpx;
  line-height: 1.6;
  resize: none;
}

/* 占位符样式 */
.form-item input::placeholder,
.form-item textarea::placeholder,
.picker .placeholder {
  color: #cccccc;
  font-size: 28rpx;
}

/* 字数统计 */
.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

/* 图片上传区域 */
.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 10rpx;
}

/* 图片预览和删除 */
.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.image-preview image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.7);
  color: #ffffff;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 2;
}

/* 上传按钮 */
.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #dddddd;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #aaaaaa;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.upload-btn:active {
  background-color: #f5f5f5;
  border-color: #07c160;
}

.upload-btn text:first-child {
  font-size: 60rpx;
  font-weight: 200;
  margin-bottom: 10rpx;
  color: #cccccc;
}

/* 选择器（地点、日期）通用样式 */
.picker {
  padding: 20rpx 0;
  color: #333333;
  font-size: 28rpx;
  position: relative;
}

/* 选择器右侧下拉箭头 */
.picker::after {
  content: "›";
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%) rotate(90deg);
  font-size: 36rpx;
  color: #cccccc;
}

/* 提交按钮区域 */
.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx 40rpx;
  background: linear-gradient(to top, #f8f9fa, rgba(248, 249, 250, 0.9));
  z-index: 100;
}

.submit-button {
  width: 100%;
  background: linear-gradient(135deg, #07c160, #05a050);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  padding: 25rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
}

.submit-button:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.4);
}

.submit-button[disabled] {
  background: linear-gradient(135deg, #cccccc, #aaaaaa);
  box-shadow: none;
  color: #eeeeee;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 错误状态提示 */
.error-tip {
  color: #ff6b6b;
  font-size: 24rpx;
  margin-top: 10rpx;
  display: flex;
  align-items: center;
}

.error-tip::before {
  content: "!";
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  line-height: 24rpx;
  text-align: center;
  background: #ff6b6b;
  color: #ffffff;
  border-radius: 50%;
  margin-right: 8rpx;
  font-size: 20rpx;
  font-weight: bold;
}
/* miniprogram/pages/me/me.wxss */
.me-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  padding-bottom: 100rpx;
  box-sizing: border-box;
}

/* 1. 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, #07c160, #05a050);
  padding: 60rpx 40rpx 80rpx;
  color: white;
  display: flex;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(7, 193, 96, 0.2);
  position: relative;
}

.avatar-section {
  margin-right: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: #f5f5f5;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.user-id, .login-tip {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 2. 数据概览卡片 */
.stats-card {
  background: white;
  margin: -40rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 40rpx 0;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 2;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 3. 功能列表 */
.menu-list {
  padding: 0 30rpx;
}

.menu-section {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-title {
  font-size: 28rpx;
  color: #999;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  position: relative;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-badge {
  background: #ff6b6b;
  color: white;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 18rpx;
  padding: 0 10rpx;
  margin-right: 20rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 36rpx;
  transform: scale(1.5, 1.5);
}

/* 退出登录按钮 */
.logout-btn {
  justify-content: center;
  border-bottom: none;
}

.logout-text {
  color: #ff6b6b;
  font-size: 30rpx;
  font-weight: 500;
}

/* 4. 登录按钮区域 */
.login-btn-section {
  padding: 60rpx 30rpx 30rpx;
  text-align: center;
}

.login-button {
  width: 100%;
  background: linear-gradient(135deg, #07c160, #05a050);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 25rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 20rpx;
}

.login-button::after {
  border: none;
}

.login-button[disabled] {
  background: linear-gradient(135deg, #cccccc, #aaaaaa);
  color: #eeeeee;
  box-shadow: none;
}

.login-protocol {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.protocol-link {
  color: #07c160;
  margin: 0 5rpx;
}

/* 5. 版本信息 */
.version-info {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  padding: 40rpx 0 20rpx;
  margin-top: 20rpx;
}